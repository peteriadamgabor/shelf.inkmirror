{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "inkmirror-shelf",
	"main": "src/worker.ts",
	"account_id": "97696f7e672a7deea8c80ab041a6ed1e",
	// Newest date the pinned wrangler 4.87.0 runtime (workerd) supports.
	"compatibility_date": "2026-05-07",

	// Custom domain — attach once DNS for shelf.inkmirror.cc exists:
	"routes": [
		{ "pattern": "shelf.inkmirror.cc", "custom_domain": true }
	],

	// Plain vars (not secrets). CHAIN_DAILY_CAP: global daily cap on
	// moderation-chain runs (shadow + listing gate) — parsed int, default 100,
	// clamped 1..10000. Code-side belt; the Anthropic console's monthly spend
	// limit is the braces.
	"vars": {
		"CHAIN_DAILY_CAP": "100"
	},

	"r2_buckets": [
		{ "binding": "SHELF_R2", "bucket_name": "inkmirror-shelf" }
	],
	"d1_databases": [
		{
			"binding": "SHELF_DB",
			"database_name": "inkmirror-shelf",
			"database_id": "e11b70cc-3cc9-45d5-956a-e9eb0a484517",
			"migrations_dir": "migrations"
		}
	],

	// Same rate-limit binding pattern as the InkMirror worker.
	// NOTE: Cloudflare ratelimit bindings only accept period 10 or 60 — the
	// spec's "5/h" budgets are approximated as small per-minute allowances.
	"unsafe": {
		"bindings": [
			{
				"name": "RL_PUBLISH",
				"type": "ratelimit",
				"namespace_id": "3001",
				"simple": { "limit": 2, "period": 60 }
			},
			{
				"name": "RL_MANAGE",
				"type": "ratelimit",
				"namespace_id": "3002",
				"simple": { "limit": 30, "period": 60 }
			},
			{
				"name": "RL_REPORT",
				"type": "ratelimit",
				"namespace_id": "3003",
				"simple": { "limit": 2, "period": 60 }
			},
			{
				// Per-IP-per-work cooldown for view counting on /w/:id —
				// one counted open per minute per (ip, work).
				"name": "RL_VIEWS",
				"type": "ratelimit",
				"namespace_id": "3004",
				"simple": { "limit": 1, "period": 60 }
			},
			{
				// Password-gate unlock attempts, keyed `${ip}:${id}` —
				// 5 tries per minute per (ip, work).
				"name": "RL_UNLOCK",
				"type": "ratelimit",
				"namespace_id": "3005",
				"simple": { "limit": 5, "period": 60 }
			},
			{
				// Reader→author letters, keyed by ip.
				"name": "RL_LETTER",
				"type": "ratelimit",
				"namespace_id": "3006",
				"simple": { "limit": 2, "period": 60 }
			}
		]
	},

	// Daily purge of expired works.
	"triggers": {
		"crons": ["17 4 * * *"]
	}

	// Secrets (set via `npx wrangler secret put`):
	//   DISCORD_WEBHOOK        — report + moderation-hold notifications
	//   ANTHROPIC_API_KEY      — Phase 2 moderation chain
	//   ADMIN_SECRET           — operator toolkit (/admin + /api/admin/*);
	//                            unset = the whole admin surface answers 404
	//   TURNSTILE_SITE_KEY     — optional Turnstile on /w/:id/report; BOTH
	//   TURNSTILE_SECRET_KEY     must be set to enable widget + verification
	//   GLITCHTIP_DSN          — server-side crash reporting (Worker exceptions
	//                            only; readers never instrumented). Unset = off.
	//   GLITCHTIP_PROXY_AUTH_VALUE — NetBird auth value guarding GlitchTip
	//                            (shared with InkMirror's tunnel)
}
